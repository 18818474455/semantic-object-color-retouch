# Python virtual environments
.venv/
.venv-m2/

# Secrets — never commit API keys
**/secrets/api.local.json
**/secrets/*.local.json
!**/secrets/*.example
.env
.env.*

# Python bytecode
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# macOS
.DS_Store
._*

# IDE
.idea/
.vscode/
*.swp

# C2 bootstrap dataset (large images; keep manifest/params/profiles in git)
**/dataset/c2/edited/
**/dataset/c2/masks/

# C1c VLM experiment crops (large images; keep the JSON report in git)
**/outputs/c1c/crops/

# C3 FG/BG visual evaluation renders (keep manifests/reviews/metrics in git)
stage0_pipeline/eval/fg_bg_coord_v1/outputs/**/*.jpg
stage0_pipeline/eval/fg_bg_coord_v1/outputs/**/*.jpeg
stage0_pipeline/eval/fg_bg_coord_v1/outputs/**/*.png

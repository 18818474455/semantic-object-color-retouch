# Python virtual environments
.venv/
.venv-m2/

# Secrets — never commit API keys
**/secrets/api.local.json
**/secrets/*.local.json
!**/secrets/*.example
.env
.env.*

# Python bytecode
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# macOS
.DS_Store
._*

# IDE
.idea/
.vscode/
*.swp

# C2 bootstrap dataset (large images; keep manifest/params/profiles in git)
**/dataset/c2/edited/
**/dataset/c2/masks/

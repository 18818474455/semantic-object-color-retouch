# secrets — never commit API keys
secrets/api.local.json
secrets/*.local.json
!secrets/*.example
.env

# python
__pycache__/
*.pyc
.venv/
.venv-m2/

# generated artifacts — keep json/csv/html reports, ignore large image blobs in git
outputs/**/*.jpg
outputs/**/*.jpeg
outputs/**/*.png
outputs/masks/
outputs/previews/
outputs/sheets/
